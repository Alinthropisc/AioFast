# ============================================================
# AioFast — Development Image
# Hot-reload, debug tools, full dev stack
# ============================================================

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    APP_ENV=local \
    SERVER_HOST=0.0.0.0 \
    SERVER_PORT=8000 \
    SERVER_RELOAD=true \
    SERVER_WORKERS=1 \
    TZ=UTC

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        git \
        build-essential \
        tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install uv for fast dependency management
RUN pip install --upgrade pip hatchling uv

# Copy dependency files first
COPY pyproject.toml README.md ./

# Install ALL deps including dev/test
RUN uv pip install --system --no-cache -e ".[dev,test]"

# Copy application (will be overridden by volume mount)
COPY . .

RUN mkdir -p storage/logs storage/cache storage/locks bootstrap/cache

EXPOSE 8000

ENTRYPOINT ["tini", "--"]
CMD ["python", "main.py"]