# ── Application ──────────────────────────────────────────
APP_NAME=AioFast
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:8000

# ── HTTP Server ──────────────────────────────────────────
SERVER_TYPE=uvicorn
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_RELOAD=false
SERVER_LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# ── Telegram bot (optional) ──────────────────────────────
# Set BOT_TOKEN to enable the Aiogram adapter.
# BOT_TOKEN=
